{
  "name": "upcover-backend",
  "version": "0.1.0",
  "description": "UpCover backend API",
  "private": true,
  "scripts": {
    "start:dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "build": "tsc",
    "reset": "rm -rf ./data ./workspaces && echo 'Cleared data/ and workspaces/'",
    "dump-logs": "ts-node scripts/dump-scan-logs.ts",
    "test": "jest",
    "test:unit": "jest --selectProjects unit",
    "test:e2e": "jest --selectProjects e2e",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/typeorm": "^10.0.0",
    "@octokit/rest": "^22.0.1",
    "better-sqlite3": "^9.4.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "simple-git": "^3.33.0",
    "typeorm": "^0.3.17"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/testing": "^10.4.22",
    "@types/better-sqlite3": "^7.6.8",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.0.0"
  }
}
